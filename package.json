{
  "name": "uni-tree-list",
  "version": "1.0.0",
  "packageManager": "pnpm@10.11.0",
  "description": "",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "main": "index.js",
  "scripts": {
    "prepare": "simple-git-hooks",
    "play": "nr -C playground dev",
    "build": "nr -r --filter=./packages/* build",
    "play:mp-weixin": "nr -C playground dev:mp-weixin",
    "build:uni": "nr build && tsx scripts/build-uni.ts",
    "build:play": "nr build:uni && nr -C playground build:h5",
    "release": "bumpp -r",
    "clean": "rimraf **/dist **/dist-resolver **/uni_modules --glob",
    "lint": "eslint --cache .",
    "lint:type": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint:fix": "nr lint --fix",
    "stylelint:fix": "stylelint **/*.{css,scss,html,vue} --fix"
  },
  "devDependencies": {
    "@antfu/ni": "catalog:",
    "@antfu/nip": "catalog:",
    "@dcloudio/types": "catalog:",
    "@mini-types/alipay": "catalog:",
    "@types/fs-extra": "catalog:",
    "@xiaohe01/eslint-config": "catalog:",
    "@xiaohe01/tsconfig": "catalog:",
    "bumpp": "catalog:",
    "chalk": "catalog:default",
    "consola": "catalog:default",
    "eslint": "catalog:",
    "fs-extra": "catalog:default",
    "lint-staged": "catalog:",
    "rimraf": "catalog:",
    "simple-git-hooks": "catalog:",
    "stylelint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue}": "eslint --fix"
  },
  "dependencies": {
    "miniprogram-api-typings": "catalog:default",
    "@uni-helper/uni-app-types": "catalog:default"
  }
}
