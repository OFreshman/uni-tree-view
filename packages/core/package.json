{
  "name": "uni-tree-list",
  "type": "module",
  "version": "1.0.3",
  "packageManager": "pnpm@10.11.0",
  "description": "一款适用于 uni-app 的树级选择列表(vue3)",
  "author": "OFreshman <415561402@qq.com>",
  "license": "MIT",
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OFreshman/uni-tree-list"
  },
  "bugs": "https://github.com/OFreshman/uni-tree-list/issues",
  "keywords": [
    "tree",
    "tree-list",
    "uniapp tree"
  ],
  "sideEffects": [
    "./src/components/**/*.vue"
  ],
  "exports": {
    ".": {
      "types": "./src/components/uni-tree-list/uni-tree-list.vue.d.ts",
      "import": "./src/components/uni-tree-list/uni-tree-list.vue"
    },
    "./shared": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js"
    },
    "./resolver": {
      "types": "./dist-resolver/resolver/index.d.ts",
      "import": "./dist-resolver/resolver/index.mjs",
      "require": "./dist-resolver/resolver/index.cjs"
    },
    "./global": "./src/global.d.ts",
    "./*": "./src/*"
  },
  "files": [
    "dist",
    "dist-resolver",
    "src"
  ],
  "scripts": {
    "build": "nr clean:dist && unbuild && tsc scripts/post-build.ts",
    "clean:dist": "rimraf ./dist ./dist-resolver"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "dependencies": {
    "@types/lodash-es": "catalog:types"
  },
  "devDependencies": {
    "@uni-helper/vite-plugin-uni-components": "catalog:build",
    "@uni-helper/vite-plugin-uni-pages": "catalog:build",
    "@vue/runtime-core": "catalog:dev",
    "lodash-es": "catalog:utils",
    "vue": "catalog:frontend"
  }
}